{
  "name": "discord-remind-bot",
  "version": "1.0.0",
  "description": "Discord bot for scheduled reminders",
  "main": "dist/index.js",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "prepare": "is-ci || lefthook install",
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "deploy-commands": "tsx src/bot/deploy.ts",
    "check": "biome check src/",
    "check:fix": "biome check --write src/",
    "format": "biome format --write src/",
    "lint": "biome lint src/"
  },
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "discord.js": "^14.25.1",
    "dotenv": "^17.3.1",
    "luxon": "^3.7.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/luxon": "^3.7.1",
    "@types/node": "^24.11.0",
    "is-ci": "^4.1.0",
    "lefthook": "^2.1.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@10.11.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@biomejs/biome",
      "better-sqlite3",
      "esbuild",
      "lefthook"
    ]
  }
}
